{
  "name": "@agent-kumite/core",
  "version": "0.0.0",
  "description": "Core runtime schemas and validation helpers for Agent Kumite.",
  "scripts": {
    "test": "vitest run",
    "build": "tsc -p tsconfig.json",
    "simulate": "node dist/cli.js",
    "report": "node dist/report-cli.js",
    "bundle": "node dist/bundle-cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "agent-kumite-harness": "./dist/cli.js",
    "agent-kumite-report": "./dist/report-cli.js",
    "agent-kumite-bundle": "./dist/bundle-cli.js"
  },
  "type": "module",
  "private": true,
  "dependencies": {
    "@sinclair/typebox": "^0.34.49"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
