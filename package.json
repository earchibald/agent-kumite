{
  "name": "@agent-kumite/core",
  "version": "0.0.0",
  "description": "Core runtime schemas and validation helpers for Agent Kumite.",
  "scripts": {
    "test": "vitest run",
    "build": "tsc -p tsconfig.json",
    "simulate": "node dist/cli.js",
    "report": "node dist/report-cli.js",
    "project": "node dist/projection-cli.js",
    "live-store": "node dist/live-run-store-cli.js",
    "live-append": "node dist/live-store-append-cli.js",
    "live-project": "node dist/live-projection-cli.js",
    "live-socket": "node dist/live-ingestion-socket-cli.js",
    "live-inspect": "node dist/live-ingestion-socket-inspect-cli.js",
    "replay": "node dist/replay-cli.js",
    "bundle": "node dist/bundle-cli.js",
    "batch": "node dist/batch-cli.js",
    "matrix": "node dist/matrix-cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "agent-kumite-harness": "./dist/cli.js",
    "agent-kumite-report": "./dist/report-cli.js",
    "agent-kumite-project": "./dist/projection-cli.js",
    "agent-kumite-live-store": "./dist/live-run-store-cli.js",
    "agent-kumite-live-append": "./dist/live-store-append-cli.js",
    "agent-kumite-live-project": "./dist/live-projection-cli.js",
    "agent-kumite-live-socket": "./dist/live-ingestion-socket-cli.js",
    "agent-kumite-live-inspect": "./dist/live-ingestion-socket-inspect-cli.js",
    "agent-kumite-replay": "./dist/replay-cli.js",
    "agent-kumite-bundle": "./dist/bundle-cli.js",
    "agent-kumite-batch": "./dist/batch-cli.js",
    "agent-kumite-matrix": "./dist/matrix-cli.js"
  },
  "type": "module",
  "private": true,
  "dependencies": {
    "@sinclair/typebox": "^0.34.49"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
